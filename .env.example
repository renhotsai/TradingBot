# Alpaca API credentials — https://app.alpaca.markets
# Default is PAPER trading. For live trading change the base URL to
# https://api.alpaca.markets and use live keys (do this only when you trust the bot).
APCA_API_KEY_ID=your_key_id
APCA_API_SECRET_KEY=your_secret_key
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Neon Postgres connection string (Vercel > Storage > Neon, or https://neon.tech)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Shared secret the external scheduler must send as "Authorization: Bearer <CRON_SECRET>"
# when calling /api/cron/tick. Generate with: openssl rand -hex 32
CRON_SECRET=change_me
